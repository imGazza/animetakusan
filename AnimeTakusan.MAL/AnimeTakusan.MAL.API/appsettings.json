{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Mal": {
    "AuthUrl": "https://myanimelist.net/v1/oauth2/token",
    "SyncActionUrl": "https://api.myanimelist.net/v2/anime/"
  },
  "RabbitMq": {
    "MalSyncAction": {
      "ExchangeName": "anime-takusan-malsync-exchange",
      "QueueName": "anime-takusan-malsync-queue",
      "PrefetchCount": 10
    },
    "MalAuthEvent": {
      "ExchangeName": "anime-takusan-malauth-exchange"
    }
  }
}