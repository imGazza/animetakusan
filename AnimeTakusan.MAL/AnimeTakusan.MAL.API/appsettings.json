{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.Environment",
      "Serilog.Expressions",
      "Serilog.Settings.Configuration",
      "Serilog.Exceptions.EntityFrameworkCore"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithExceptionDetails"
    ],
    "Properties": {
      "Application": "MyAnimeList MS"
    },
    "WriteTo:Console": {
      "Name": "Console",
      "Args": {
        "outputTemplate": "{Timestamp:HH:mm:ss.fff} - {EnvironmentName} - [{Level:u3}] [{Area}] {Message:lj}{NewLine}{Exception}"
      }
    },
    "WriteTo:Seq": {
      "Name": "Seq",
      "Args": {
        "serverUrl": "%SEQ_SERVER%",
        "apiKey": "%SEQ_API_KEY%"
      }
    }
  },
  "AllowedHosts": "*",
  "Mal": {
    "AuthUrl": "https://myanimelist.net/v1/oauth2/token",
    "SyncActionUrl": "https://api.myanimelist.net/v2/anime/"
  },
  "RabbitMq": {
    "MalSyncAction": {
      "ExchangeName": "anime-takusan-malsync-exchange",
      "QueueName": "anime-takusan-malsync-queue",
      "PrefetchCount": 10
    },
    "MalAuthEvent": {
      "ExchangeName": "anime-takusan-malauth-exchange"
    }
  }
}