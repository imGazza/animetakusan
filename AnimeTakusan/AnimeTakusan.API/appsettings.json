{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.Environment",
      "Serilog.Expressions",
      "Serilog.Settings.Configuration",
      "Serilog.Exceptions.EntityFrameworkCore"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithExceptionDetails",
      {
        "Name": "WithComputed",
        "Args": {
          "propertyName": "Area",
          "expression": "if SourceContext like 'RequestLoggingMiddleware%' then 'HTTP' else if SourceContext like 'AnimeTakusan.API%' then 'API' else if SourceContext like 'AnimeTakusan.AnimeProviders%' then 'AnimeProviders' else if SourceContext like 'AnimeTakusan.Infrastructure%' then 'Infrastructure' else if SourceContext like 'AnimeTakusan.Application%' then 'Application' else 'Other'"
        }
      }
    ],
    "Properties": {
      "Application": "Main"
    },
    "WriteTo:Console": {
      "Name": "Console",
      "Args": {
        "outputTemplate": "{Timestamp:HH:mm:ss.fff} - {EnvironmentName} - [{Level:u3}] [{Area}] {Message:lj}{NewLine}{Exception}"
      }
    },
    "WriteTo:Seq": {
      "Name": "Seq",
      "Args": {
        "serverUrl": "%SEQ_SERVER%",
        "apiKey": "%SEQ_API_KEY%"
      }
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://animetakusan.eu",
    "https://www.animetakusan.eu"
  ],
  "CookiesSettings": {
    "SameSite": "Lax",
    "Secure": true,
    "Domain": ".animetakusan.eu"
  },
  "AniList": {
    "ApiUrl": "https://graphql.anilist.co"
  },
  "AniListAuth": {
    "RedirectUri": "https://animetakusan.eu/anilist/callback",
    "CodeExchangeUrl": "https://anilist.co/api/v2/oauth/authorize",
    "TokenExchangeUrl": "https://anilist.co/api/v2/oauth/token"
  },
  "RabbitMq": {
    "MalSyncAction": {
      "ExchangeName": "anime-takusan-malsync-exchange"
    },
    "MalAuthEvent": {
      "VirtualHost": "/",
      "ExchangeName": "anime-takusan-malauth-exchange",
      "QueueName": "anime-takusan-malauth-queue",
      "PrefetchCount": 10
    }
  },
  "Mal": {
    "AuthUrl": "https://myanimelist.net/v1/oauth2/authorize"
  },
  "Cache": {
    "AniListTokenTtlDays": 30,
    "AniListUserTtlHours": 24,
    "AniListLibraryTtlMinutes": 10,
    "AniListPublicDataTtlHours": 24
  }
}